@implements IDisposable
@inject ClipboardService Clipboard

<button type="button"
        class="@CssClass"
        @onclick="Copy"
        disabled="@string.IsNullOrEmpty(Text)"
        aria-label="Copy to clipboard">
    @if (_copied)
    {
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 6 9 17l-5-5"/>
        </svg>
        <span>Copied</span>
    }
    else
    {
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2"/>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
        <span>@Label</span>
    }
</button>

@code {
    [Parameter] public string? Text { get; set; }
    [Parameter] public string Label { get; set; } = "Copy";
    [Parameter] public bool Inline { get; set; }

    private bool _copied;
    private CancellationTokenSource? _cts;

    private string CssClass => Inline ? "copy-btn copy-btn--inline" + Flag : "copy-btn" + Flag;
    private string Flag => _copied ? " copied" : "";

    private async Task Copy()
    {
        if (string.IsNullOrEmpty(Text)) return;
        var ok = await Clipboard.CopyAsync(Text);
        if (!ok) return;

        _copied = true;
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;
        try
        {
            await Task.Delay(2000, token);
            _copied = false;
            StateHasChanged();
        }
        catch (TaskCanceledException) { /* superseded by a newer copy */ }
    }

    public void Dispose() => _cts?.Cancel();
}
